# LLM Provider API Keys (at least one required — Gemini/Groq are free)
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Vector DB Settings
CHROMA_URL=http://localhost:8000

# E2B Sandbox — Secure Python code execution (https://e2b.dev)
E2B_API_KEY=your_e2b_api_key_here

# Langfuse Observability — LLM tracing & monitoring (https://langfuse.com)
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Supabase — Production database (https://supabase.com)
# Leave empty to use the SQLite Data Lake repository
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# JWT Authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-strong-random-secret-min-32-chars-here
JWT_EXPIRES_IN=1h

# API Server port (optional)
API_PORT=3001

# Meta (Facebook/Instagram) OAuth Integration
# Create your Meta App at https://developers.facebook.com
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:3001/api/meta/callback

# Encryption key for Meta API token storage (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️  If you rotate this key, set the OLD key as ENCRYPTION_KEY_PREVIOUS so existing
#    tokens can still be decrypted. Tokens will be re-encrypted with the new key on access.
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here
# ENCRYPTION_KEY_PREVIOUS=previous-64-char-hex-key-here (only needed during key rotation)

# MCP Identity / Tenant Isolation context
# Defines which user's private tables the MCP stdio connection can access.
# Defaults to 'system' (shared tables only) if omitted. Set to a specific userId for private table access.
MCP_USER_ID=system
