# LLM Provider API Keys (at least one required — Gemini/Groq are free)
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Vector DB Settings
CHROMA_URL=http://localhost:8000

# E2B Sandbox — Secure Python code execution (https://e2b.dev)
E2B_API_KEY=your_e2b_api_key_here

# Langfuse Observability — LLM tracing & monitoring (https://langfuse.com)
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Supabase — Production database (https://supabase.com)
# Leave empty to use the SQLite Data Lake repository
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# JWT Authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-strong-random-secret-min-32-chars-here
JWT_EXPIRES_IN=1h

# API Server port (optional)
API_PORT=3001

# MCP Identity / Tenant Isolation context
# Defines which user's private tables the MCP stdio connection can access.
# Defaults to 'system' (shared tables only) if omitted. Set to a specific userId for private table access.
MCP_USER_ID=system
